{
  "meshConfig": {
    "sources": [
      {
        "name": "MDMData",
        "handler": {
          "JsonSchema": {
            "baseUrl": "{env.BASE_URL}/mdm-data",
            "operationHeaders": {
              "x-forwarded-authorization": "{context.headers['authorization']}"
            },
            "operations": [
              {
                "type": "Query",
                "field": "mdmQuery",
                "path": "/?entity={args.entity}&page={args.page}&pageSize={args.pageSize}&sort={args.sort}&order={args.order}&fields={args.fields}&facets={args.facets}&filters={args.filters}",
                "method": "GET",
                "responseSchema": "./response-schemas/mdm-query.schema.json",
                "argTypeMap": {
                  "entity": {
                    "type": "String!"
                  },
                  "page": {
                    "type": "Int"
                  },
                  "pageSize": {
                    "type": "Int"
                  },
                  "sort": {
                    "type": "String"
                  },
                  "order": {
                    "type": "String"
                  },
                  "fields": {
                    "type": "String"
                  },
                  "facets": {
                    "type": "String"
                  },
                  "filters": {
                    "type": "String"
                  }
                }
              },
              {
                "type": "Query",
                "field": "mdmRecord",
                "path": "/?entity={args.entity}&id={args.id}",
                "method": "GET",
                "responseSchema": "./response-schemas/mdm-record.schema.json",
                "argTypeMap": {
                  "entity": {
                    "type": "String!"
                  },
                  "id": {
                    "type": "String!"
                  }
                }
              }
            ]
          }
        }
      },
      {
        "name": "MDMFacets",
        "handler": {
          "JsonSchema": {
            "baseUrl": "{env.BASE_URL}/mdm-facets",
            "operationHeaders": {
              "x-forwarded-authorization": "{context.headers['authorization']}"
            },
            "operations": [
              {
                "type": "Query",
                "field": "mdmFacets",
                "path": "/?entity={args.entity}&values={args.values}&filters={args.filters}",
                "method": "GET",
                "responseSchema": "./response-schemas/mdm-facets.schema.json",
                "argTypeMap": {
                  "entity": {
                    "type": "String!"
                  },
                  "values": {
                    "type": "String"
                  },
                  "filters": {
                    "type": "String"
                  }
                }
              }
            ]
          }
        }
      }
    ],
    "responseConfig": {
      "headers": {
        "Cache-Control": "public, max-age=60, s-maxage=120"
      }
    }
  }
}
