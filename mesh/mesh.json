{
  "meshConfig": {
    "sources": [
      {
        "name": "MDMData",
        "handler": {
          "JsonSchema": {
            "baseUrl": "{env.BASE_URL}/mdm-data",
            "operationHeaders": {
              "x-forwarded-authorization": "{context.headers['authorization']}",
              "x-forwarded-x-partner-id": "{context.headers['x-partner-id']}",
              "x-forwarded-x-partner-key": "{context.headers['x-partner-key']}"
            },
            "operations": [
              {
                "type": "Query",
                "field": "mdmQuery",
                "path": "/?master={args.master}&page={args.page}&pageSize={args.pageSize}&sort={args.sort}&order={args.order}&fields={args.fields}&facets={args.facets}&filters={args.filters}",
                "method": "GET",
                "responseSchema": "./response-schemas/mdm-query.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  },
                  "page": {
                    "type": "Int"
                  },
                  "pageSize": {
                    "type": "Int"
                  },
                  "sort": {
                    "type": "String"
                  },
                  "order": {
                    "type": "String"
                  },
                  "fields": {
                    "type": "String"
                  },
                  "facets": {
                    "type": "String"
                  },
                  "filters": {
                    "type": "String"
                  }
                }
              },
              {
                "type": "Query",
                "field": "mdmRecord",
                "path": "/?master={args.master}&id={args.id}",
                "method": "GET",
                "responseSchema": "./response-schemas/mdm-record.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  },
                  "id": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmCreate",
                "path": "/?master={args.master}&operation=create",
                "method": "POST",
                "requestSchema": "./request-schemas/mutation-req.json",
                "responseSchema": "./response-schemas/mdm-mutation.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmUpdate",
                "path": "/?master={args.master}&id={args.id}&operation=update",
                "method": "POST",
                "requestSchema": "./request-schemas/mutation-req.json",
                "responseSchema": "./response-schemas/mdm-mutation.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  },
                  "id": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmPatch",
                "path": "/?master={args.master}&id={args.id}&operation=patch",
                "method": "POST",
                "requestSchema": "./request-schemas/mutation-req.json",
                "responseSchema": "./response-schemas/mdm-mutation.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  },
                  "id": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmDelete",
                "path": "/?master={args.master}&id={args.id}&operation=delete",
                "method": "POST",
                "responseSchema": "./response-schemas/mdm-mutation.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  },
                  "id": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Query",
                "field": "mdmBulkFetch",
                "path": "/?master={args.master}&ids={args.ids}",
                "method": "GET",
                "responseSchema": "./response-schemas/bulk-fetch.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  },
                  "ids": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmBulkCreate",
                "path": "/?master={args.master}&operation=bulkCreate",
                "method": "POST",
                "requestSchema": "./request-schemas/mutation-req.json",
                "responseSchema": "./response-schemas/bulk-resp.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmBulkUpdate",
                "path": "/?master={args.master}&operation=bulkUpdate",
                "method": "POST",
                "requestSchema": "./request-schemas/mutation-req.json",
                "responseSchema": "./response-schemas/bulk-resp.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmBulkPatch",
                "path": "/?master={args.master}&operation=bulkPatch",
                "method": "POST",
                "requestSchema": "./request-schemas/mutation-req.json",
                "responseSchema": "./response-schemas/bulk-resp.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  }
                }
              },
              {
                "type": "Mutation",
                "field": "mdmBulkDelete",
                "path": "/?master={args.master}&operation=bulkDelete",
                "method": "POST",
                "requestSchema": "./request-schemas/mutation-req.json",
                "responseSchema": "./response-schemas/bulk-resp.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  }
                }
              }
            ]
          }
        }
      },
      {
        "name": "MDMFacets",
        "handler": {
          "JsonSchema": {
            "baseUrl": "{env.BASE_URL}/mdm-facets",
            "operationHeaders": {
              "x-forwarded-authorization": "{context.headers['authorization']}"
            },
            "operations": [
              {
                "type": "Query",
                "field": "mdmFacets",
                "path": "/?master={args.master}&values={args.values}&filters={args.filters}",
                "method": "GET",
                "responseSchema": "./response-schemas/mdm-facets.schema.json",
                "argTypeMap": {
                  "master": {
                    "type": "String!"
                  },
                  "values": {
                    "type": "String"
                  },
                  "filters": {
                    "type": "String"
                  }
                }
              }
            ]
          }
        }
      }
    ]
  }
}
