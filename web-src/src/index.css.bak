/*
 * DataHub — Enterprise Master Data Platform Stylesheet
 */

/* ========================================
   BASE
   ======================================== */

html,
body {
  margin: 0;
  font-family: adobe-clean, 'Source Sans Pro', -apple-system, BlinkMacSystemFont, sans-serif;
}

*, *::before, *::after {
  box-sizing: border-box;
}

/* ========================================
   APP SHELL LAYOUT
   ======================================== */

.mdm-app-shell {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

.mdm-sidebar-container {
  width: 260px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--spectrum-global-color-gray-50, #fff);
  border-right: 1px solid var(--spectrum-global-color-gray-200, #e1e1e1);
  overflow: auto;
}

.mdm-main-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}

.mdm-main-content {
  flex: 1;
  overflow: auto;
  padding: 24px 32px;
}

/* ========================================
   SIDEBAR
   ======================================== */

.mdm-sidebar {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.mdm-sidebar__brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 20px 20px 16px;
}

.mdm-sidebar__brand-icon {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, #1473E6, #0D66D0);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

.mdm-sidebar__brand-text {
  display: flex;
  flex-direction: column;
}

.mdm-sidebar__brand-title {
  font-size: 15px !important;
  font-weight: 700 !important;
  color: var(--spectrum-global-color-gray-900);
}

.mdm-sidebar__brand-subtitle {
  font-size: 11px !important;
  color: var(--spectrum-global-color-gray-600);
  margin-top: 1px;
}

.mdm-sidebar__nav {
  flex: 1;
  padding: 8px 12px;
  overflow-y: auto;
}

.mdm-sidebar__section {
  margin-bottom: 20px;
}

.mdm-sidebar__section-label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--spectrum-global-color-gray-500);
  padding: 0 8px;
  margin-bottom: 4px;
}

.mdm-sidebar__footer {
  margin-top: auto;
  padding: 12px 20px;
}

.mdm-sidebar__env-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 0;
}

.mdm-sidebar__env-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #12805C;
  animation: pulse 2s infinite;
}

.mdm-sidebar__env-text {
  font-size: 11px !important;
  color: var(--spectrum-global-color-gray-600);
}

.mdm-sidebar__version-text {
  font-size: 10px !important;
  color: var(--spectrum-global-color-gray-400);
  margin-top: 4px;
  display: block;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* Side Nav Items */
.SideNav {
  list-style-type: none;
  margin: 0;
  padding: 0;
  outline: none;
}

.SideNav-item {
  list-style-type: none;
  margin: 2px 0;
}

.SideNav-itemLink {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: start;
  gap: 10px;
  box-sizing: border-box;
  width: 100%;
  min-height: 36px;
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 400;
  text-decoration: none;
  word-break: break-word;
  cursor: pointer;
  background-color: transparent;
  color: var(--spectrum-global-color-gray-700);
  transition: all 0.15s ease;
}

.SideNav-itemLink:hover {
  background-color: var(--spectrum-global-color-gray-200);
  color: var(--spectrum-global-color-gray-900);
}

.SideNav-itemLink.is-selected {
  color: var(--spectrum-global-color-blue-600);
  background-color: var(--spectrum-global-color-blue-100);
  font-weight: 600;
}

.SideNav-itemLink.is-selected::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6px;
  bottom: 6px;
  width: 3px;
  border-radius: 2px;
  background: var(--spectrum-global-color-blue-600);
}

.SideNav-itemIcon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.SideNav-itemLabel {
  flex: 1;
}

/* ========================================
   HEADER BAR
   ======================================== */

.mdm-header {
  position: sticky;
  top: 0;
  z-index: 100;
}

.mdm-header__user-badge {
  background: var(--spectrum-global-color-gray-200);
  border-radius: 20px;
  padding: 4px 12px 4px 4px;
}

.mdm-header__avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, #1473E6, #0D66D0);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.mdm-breadcrumbs {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
}

.mdm-breadcrumbs__separator {
  color: var(--spectrum-global-color-gray-400);
  margin: 0 2px;
}

.mdm-breadcrumbs__link {
  background: none;
  border: none;
  color: var(--spectrum-global-color-blue-600);
  cursor: pointer;
  font-size: 13px;
  padding: 2px 4px;
  border-radius: 3px;
}

.mdm-breadcrumbs__link:hover {
  background: var(--spectrum-global-color-blue-100);
}

.mdm-breadcrumbs__current {
  color: var(--spectrum-global-color-gray-800);
  font-weight: 600;
}

/* ========================================
   MAIN CONTENT & PAGES
   ======================================== */

.mdm-main-content {
  background-color: var(--spectrum-global-color-gray-50);
}

.mdm-page__title {
  margin-bottom: 0 !important;
  font-size: 24px !important;
  font-weight: 700 !important;
  color: var(--spectrum-global-color-gray-900);
}

.mdm-page__subtitle {
  font-size: 13px !important;
  color: var(--spectrum-global-color-gray-600);
  margin-top: 4px;
}

/* ========================================
   CARDS
   ======================================== */

.mdm-card {
  background: white;
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 8px;
  padding: 24px;
}

/* ========================================
   KPI CARDS
   ======================================== */

.mdm-kpi-card {
  background: white;
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 8px;
  padding: 20px 24px;
  position: relative;
  overflow: hidden;
}

.mdm-kpi-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
}

.mdm-kpi-card--blue::before { background: #1473E6; }
.mdm-kpi-card--green::before { background: #12805C; }
.mdm-kpi-card--purple::before { background: #7C3AED; }
.mdm-kpi-card--orange::before { background: #E68619; }

.mdm-kpi-card__title {
  font-size: 12px !important;
  font-weight: 600 !important;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--spectrum-global-color-gray-600);
  display: block;
}

.mdm-kpi-card__value {
  font-size: 32px !important;
  font-weight: 700 !important;
  color: var(--spectrum-global-color-gray-900);
  display: block;
  margin: 8px 0 4px;
  line-height: 1;
}

.mdm-kpi-card__subtitle {
  font-size: 12px !important;
  color: var(--spectrum-global-color-gray-500);
  display: block;
}

/* ========================================
   TABLES
   ======================================== */

.mdm-table-container {
  overflow-x: auto;
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 8px;
  background: white;
}

.mdm-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.mdm-table th,
.mdm-table td {
  padding: 12px 16px;
  text-align: left;
  border-bottom: 1px solid var(--spectrum-global-color-gray-200);
}

.mdm-table th {
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--spectrum-global-color-gray-600);
  background-color: var(--spectrum-global-color-gray-75);
  white-space: nowrap;
  position: sticky;
  top: 0;
}

.mdm-table--compact th,
.mdm-table--compact td {
  padding: 8px 12px;
}

.mdm-table--hoverable tbody tr:hover {
  background-color: var(--spectrum-global-color-gray-75);
}

.mdm-table__clickable-row {
  cursor: pointer;
}

.mdm-table__clickable-row:hover {
  background-color: var(--spectrum-global-color-blue-50) !important;
}

.mdm-table__row--selected {
  background-color: var(--spectrum-global-color-blue-50) !important;
}

.mdm-table__sortable-header {
  cursor: pointer;
  user-select: none;
  transition: color 0.15s;
}

.mdm-table__sortable-header:hover {
  color: var(--spectrum-global-color-blue-600);
}

.mdm-table__header-content {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.mdm-table__sort-indicator {
  margin-left: 2px;
  font-size: 10px;
  color: var(--spectrum-global-color-gray-400);
  transition: color 0.15s;
}

.mdm-table__sort-indicator--active {
  color: var(--spectrum-global-color-blue-600);
  font-weight: 700;
}

.mdm-table__sortable-header:hover .mdm-table__sort-indicator {
  color: var(--spectrum-global-color-blue-500);
}

.mdm-badge-queryable {
  display: inline-block;
  background: var(--spectrum-global-color-blue-400);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  padding: 1px 4px;
  border-radius: 3px;
  vertical-align: middle;
}

.mdm-table__check-col {
  width: 40px;
  text-align: center !important;
}

.mdm-table__actions-col {
  width: 60px;
  text-align: right !important;
  white-space: nowrap;
}

.mdm-table tbody tr:last-child td {
  border-bottom: none;
}

/* ========================================
   ENTITY CELL
   ======================================== */

.mdm-entity-cell {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.mdm-entity-cell__link {
  background: none;
  border: none;
  padding: 0;
  color: var(--spectrum-global-color-blue-600);
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  text-align: left;
}

.mdm-entity-cell__link:hover {
  text-decoration: underline;
}

.mdm-entity-cell__sub {
  font-size: 11px;
  color: var(--spectrum-global-color-gray-500);
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
}

/* ========================================
   DETAIL LIST
   ======================================== */

.mdm-detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.mdm-detail-list {
  display: flex;
  flex-direction: column;
}

.mdm-detail-list__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--spectrum-global-color-gray-200);
}

.mdm-detail-list__row:last-child {
  border-bottom: none;
}

.mdm-detail-list__label {
  font-size: 13px;
  color: var(--spectrum-global-color-gray-600);
  font-weight: 500;
}

.mdm-detail-list__value {
  font-size: 13px;
  color: var(--spectrum-global-color-gray-900);
  font-weight: 600;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

/* ========================================
   CODE BLOCKS
   ======================================== */

.mdm-code-block {
  border: 1px solid var(--spectrum-global-color-gray-300);
  border-radius: 6px;
  overflow: hidden;
  margin-top: 8px;
}

.mdm-code-block__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 12px;
  background: var(--spectrum-global-color-gray-100);
  border-bottom: 1px solid var(--spectrum-global-color-gray-300);
  font-size: 11px;
  font-weight: 600;
  color: var(--spectrum-global-color-gray-600);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.mdm-code-block__content {
  margin: 0;
  padding: 16px;
  background: var(--spectrum-global-color-gray-50);
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  font-size: 12px;
  line-height: 1.5;
  overflow-x: auto;
  color: var(--spectrum-global-color-gray-800);
}

.mdm-code-inline {
  background: var(--spectrum-global-color-gray-100);
  padding: 2px 6px;
  border-radius: 3px;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  font-size: 12px;
}

.mdm-code-badge {
  display: inline-block;
  background: var(--spectrum-global-color-blue-100);
  color: var(--spectrum-global-color-blue-700);
  padding: 3px 8px;
  border-radius: 4px;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  font-size: 12px;
  font-weight: 500;
}

/* ========================================
   BADGES
   ======================================== */

.mdm-badge-pk {
  display: inline-block;
  background: var(--spectrum-global-color-yellow-400);
  color: var(--spectrum-global-color-gray-800);
  font-size: 9px;
  font-weight: 700;
  padding: 1px 4px;
  border-radius: 3px;
  margin-left: 6px;
  vertical-align: middle;
}

/* ========================================
   TOOLBAR
   ======================================== */

.mdm-toolbar {
  background: white;
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 8px;
  padding: 16px;
}

/* ========================================
   FORM GRID
   ======================================== */

.mdm-form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* ========================================
   STEPPER (Upload Wizard)
   ======================================== */

.mdm-stepper {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 32px;
  padding: 16px 0;
}

.mdm-stepper__step {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  position: relative;
}

.mdm-stepper__step::after {
  content: '';
  flex: 1;
  height: 2px;
  background: var(--spectrum-global-color-gray-300);
  margin: 0 8px;
}

.mdm-stepper__step:last-child::after {
  display: none;
}

.mdm-stepper__step--complete::after {
  background: var(--spectrum-global-color-blue-500);
}

.mdm-stepper__number {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  background: var(--spectrum-global-color-gray-200);
  color: var(--spectrum-global-color-gray-600);
  flex-shrink: 0;
}

.mdm-stepper__step--active .mdm-stepper__number {
  background: var(--spectrum-global-color-blue-500);
  color: white;
}

.mdm-stepper__step--complete .mdm-stepper__number {
  background: var(--spectrum-global-color-green-500);
  color: white;
}

.mdm-stepper__label {
  font-size: 11px;
  font-weight: 500;
  color: var(--spectrum-global-color-gray-500);
  white-space: nowrap;
}

.mdm-stepper__step--active .mdm-stepper__label {
  color: var(--spectrum-global-color-blue-600);
  font-weight: 700;
}

.mdm-stepper__step--complete .mdm-stepper__label {
  color: var(--spectrum-global-color-green-700);
}

/* ========================================
   DROPZONE
   ======================================== */

.mdm-dropzone {
  border: 2px dashed var(--spectrum-global-color-gray-300);
  border-radius: 12px;
  padding: 60px 40px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s ease;
  background: white;
}

.mdm-dropzone:hover {
  border-color: var(--spectrum-global-color-blue-400);
  background: var(--spectrum-global-color-blue-50);
}

.mdm-dropzone--active {
  border-color: var(--spectrum-global-color-blue-500);
  background: var(--spectrum-global-color-blue-100);
  transform: scale(1.01);
}

.mdm-dropzone--has-file {
  border-color: var(--spectrum-global-color-green-400);
  border-style: solid;
}

.mdm-dropzone__prompt,
.mdm-dropzone__success {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.mdm-dropzone__icon {
  font-size: 48px;
  margin-bottom: 8px;
}

/* ========================================
   EMPTY STATES
   ======================================== */

.mdm-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  text-align: center;
}

.mdm-empty-state--compact {
  padding: 24px 16px;
}

.mdm-empty-state__icon {
  font-size: 48px;
  margin-bottom: 16px;
}

/* ========================================
   SUCCESS STATE
   ======================================== */

.mdm-success-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 40px 20px;
}

.mdm-success-state__icon {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--spectrum-global-color-green-100);
  color: var(--spectrum-global-color-green-700);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 16px;
}

/* ========================================
   LOADING STATE
   ======================================== */

.mdm-loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 40px;
}

/* ========================================
   ALERTS
   ======================================== */

.mdm-alert {
  border-radius: 6px;
  padding: 12px 16px;
}

.mdm-alert--error {
  background: var(--spectrum-global-color-red-100);
  border: 1px solid var(--spectrum-global-color-red-400);
}

.mdm-alert--error span {
  color: var(--spectrum-global-color-red-700) !important;
}

/* ========================================
   ACTIVITY TIMELINE
   ======================================== */

.mdm-activity-timeline {
  display: flex;
  flex-direction: column;
}

.mdm-activity-timeline__item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--spectrum-global-color-gray-100);
}

.mdm-activity-timeline__item:last-child {
  border-bottom: none;
}

.mdm-activity-timeline__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-top: 6px;
  flex-shrink: 0;
}

.mdm-activity-timeline__dot--success {
  background: var(--spectrum-global-color-green-500);
}

.mdm-activity-timeline__dot--error {
  background: var(--spectrum-global-color-red-500);
}

.mdm-activity-timeline__content {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.mdm-activity-timeline__action {
  font-size: 13px !important;
}

.mdm-activity-timeline__meta {
  font-size: 11px !important;
  color: var(--spectrum-global-color-gray-500);
}

/* ========================================
   TOAST NOTIFICATIONS
   ======================================== */

.mdm-toast-container {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 10000;
  display: flex;
  flex-direction: column-reverse;
  gap: 8px;
  max-width: 420px;
}

.mdm-toast {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  border-radius: 8px;
  background: white;
  border: 1px solid var(--spectrum-global-color-gray-200);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.08);
  animation: slideInRight 0.3s ease-out;
  font-size: 13px;
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.mdm-toast--positive { border-left: 4px solid var(--spectrum-global-color-green-500); }
.mdm-toast--negative { border-left: 4px solid var(--spectrum-global-color-red-500); }
.mdm-toast--info { border-left: 4px solid var(--spectrum-global-color-blue-500); }
.mdm-toast--notice { border-left: 4px solid var(--spectrum-global-color-orange-500); }

.mdm-toast__icon {
  font-size: 16px;
  flex-shrink: 0;
}

.mdm-toast--positive .mdm-toast__icon { color: var(--spectrum-global-color-green-600); }
.mdm-toast--negative .mdm-toast__icon { color: var(--spectrum-global-color-red-600); }
.mdm-toast--info .mdm-toast__icon { color: var(--spectrum-global-color-blue-600); }
.mdm-toast--notice .mdm-toast__icon { color: var(--spectrum-global-color-orange-600); }

.mdm-toast__message {
  flex: 1;
  color: var(--spectrum-global-color-gray-800);
}

.mdm-toast__close {
  background: none;
  border: none;
  font-size: 18px;
  cursor: pointer;
  color: var(--spectrum-global-color-gray-500);
  padding: 0 4px;
  line-height: 1;
}

.mdm-toast__close:hover {
  color: var(--spectrum-global-color-gray-800);
}

/* ========================================
   PAGINATION
   ======================================== */

.mdm-pagination {
  padding: 16px 0;
}

.mdm-pagination__current {
  font-weight: 600;
  font-size: 13px;
  color: var(--spectrum-global-color-gray-700);
}

/* ========================================
   UTILITY CLASSES
   ======================================== */

.mdm-text-muted {
  color: var(--spectrum-global-color-gray-500) !important;
  font-size: 12px !important;
}

.mdm-text-mono {
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace !important;
  font-size: 12px !important;
}

.mdm-btn-danger {
  color: var(--spectrum-global-color-red-600) !important;
}

.mdm-file-input {
  font-size: 13px;
  padding: 8px 0;
}

.mdm-cell-value {
  display: block;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========================================
   ERROR FALLBACK
   ======================================== */

.mdm-error-fallback {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 40px;
  text-align: center;
  font-family: adobe-clean, sans-serif;
}

.mdm-error-fallback__icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.mdm-error-fallback h1 {
  margin: 0 0 8px;
  font-size: 24px;
}

.mdm-error-fallback p {
  color: #666;
  margin: 0 0 24px;
}

.mdm-error-fallback details {
  text-align: left;
  max-width: 600px;
  margin-bottom: 24px;
}

.mdm-error-fallback pre {
  background: #f5f5f5;
  padding: 16px;
  border-radius: 8px;
  font-size: 12px;
  overflow-x: auto;
  max-height: 200px;
}

.mdm-error-fallback button {
  background: #1473E6;
  color: white;
  border: none;
  padding: 10px 24px;
  border-radius: 6px;
  font-size: 14px;
  cursor: pointer;
}

.mdm-error-fallback button:hover {
  background: #0D66D0;
}

/* ========================================
   DASHBOARD GRIDS (responsive)
   ======================================== */

.mdm-kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.mdm-dashboard-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 24px;
  margin-bottom: 24px;
}

/* ========================================
   RESPONSIVE
   ======================================== */

/* ── Tablet (768–1024px) ── */
@media (max-width: 1024px) {
  .mdm-detail-grid {
    grid-template-columns: 1fr;
  }
  .mdm-form-grid {
    grid-template-columns: 1fr;
  }
  .admin-kpi-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .mdm-kpi-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .mdm-dashboard-grid {
    grid-template-columns: 1fr;
  }
  .mdm-page__title {
    font-size: 20px !important;
  }
  .mdm-kpi-card__value {
    font-size: 26px !important;
  }
  .mdm-card {
    padding: 16px;
  }
  .mdm-dropzone {
    padding: 40px 24px;
  }
  .mdm-stepper__label {
    display: none;
  }
}

/* ── Mobile (<768px) ── */
@media (max-width: 768px) {
  /* Sidebar: hidden by default, shown as overlay via JS toggle */
  .mdm-sidebar-container {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 280px;
    z-index: 1000;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    background: var(--spectrum-global-color-gray-50, #fff);
    box-shadow: none;
  }
  .mdm-sidebar-container.mdm-sidebar--open {
    transform: translateX(0);
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.15);
  }

  /* Backdrop overlay when sidebar is open */
  .mdm-sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(0, 0, 0, 0.4);
  }
  .mdm-sidebar-backdrop.mdm-sidebar-backdrop--visible {
    display: block;
  }

  /* Main layout becomes single column */
  .mdm-app-grid {
    display: flex !important;
    flex-direction: column !important;
    height: 100vh;
  }
  .mdm-app-grid > [class*="gridArea-sidebar"] {
    display: none !important;
  }

  /* Header compact */
  .mdm-header {
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .mdm-breadcrumbs {
    font-size: 12px;
    overflow: hidden;
    white-space: nowrap;
  }
  .mdm-header__user-badge {
    display: none;
  }

  /* Hamburger button visible */
  .mdm-hamburger {
    display: flex !important;
  }

  /* Content area */
  .mdm-main-content {
    padding: 16px !important;
    flex: 1;
    overflow: auto;
  }

  /* Page titles */
  .mdm-page__title {
    font-size: 18px !important;
  }
  .mdm-page__subtitle {
    font-size: 12px !important;
  }

  /* KPI cards: stack single column */
  .admin-kpi-grid {
    grid-template-columns: 1fr;
  }
  .mdm-kpi-grid {
    grid-template-columns: 1fr;
  }
  .mdm-dashboard-grid {
    grid-template-columns: 1fr;
  }
  .mdm-kpi-card {
    padding: 14px 16px;
  }
  .mdm-kpi-card__value {
    font-size: 24px !important;
  }

  /* Cards */
  .mdm-card {
    padding: 14px;
  }
  .mdm-toolbar {
    padding: 12px;
  }

  /* Tables: horizontal scroll, compact */
  .mdm-table-container {
    margin-left: -16px;
    margin-right: -16px;
    border-radius: 0;
    border-left: none;
    border-right: none;
  }
  .mdm-table th,
  .mdm-table td {
    padding: 10px 12px;
    font-size: 12px;
  }

  /* Detail grid: single column */
  .mdm-detail-grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .mdm-detail-list__row {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    padding: 8px 0;
  }
  .mdm-detail-list__value {
    text-align: left;
    max-width: 100%;
  }

  /* Form: single column */
  .mdm-form-grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  /* Stepper: numbers only */
  .mdm-stepper {
    margin-bottom: 20px;
    padding: 12px 0;
  }
  .mdm-stepper__label {
    display: none;
  }

  /* Dropzone compact */
  .mdm-dropzone {
    padding: 32px 16px;
  }
  .mdm-dropzone__icon {
    font-size: 36px;
  }

  /* Empty states compact */
  .mdm-empty-state {
    padding: 32px 16px;
  }

  /* Code blocks */
  .mdm-code-block__content {
    font-size: 11px;
    padding: 12px;
  }

  /* Toast: full width at bottom */
  .mdm-toast-container {
    left: 16px;
    right: 16px;
    bottom: 16px;
    max-width: none;
  }

  /* Pagination compact */
  .mdm-pagination {
    padding: 12px 0;
  }

  /* Admin bar chart */
  .admin-bar-chart {
    height: 80px;
  }

  /* Error fallback */
  .mdm-error-fallback {
    padding: 24px 16px;
  }
  .mdm-error-fallback pre {
    font-size: 10px;
    max-height: 150px;
  }
}

/* ── Small mobile (<480px) ── */
@media (max-width: 480px) {
  .mdm-page__title {
    font-size: 16px !important;
  }
  .mdm-kpi-card__value {
    font-size: 20px !important;
  }
  .mdm-table th,
  .mdm-table td {
    padding: 8px 10px;
    font-size: 11px;
  }
  .mdm-breadcrumbs {
    font-size: 11px;
  }
  .mdm-breadcrumbs__link,
  .mdm-breadcrumbs__current {
    font-size: 11px;
  }
}

/* ── Hamburger button: hidden on desktop ── */
.mdm-hamburger {
  display: none !important;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  border-radius: 4px;
  color: var(--spectrum-global-color-gray-700);
}
.mdm-hamburger:hover {
  background: var(--spectrum-global-color-gray-200);
}
.mdm-hamburger svg {
  width: 20px;
  height: 20px;
}

/* ========================================
   ADMIN CONSOLE
   ======================================== */

.admin-kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.admin-kpi-metric {
  background: var(--spectrum-global-color-gray-50, #fff);
  border: 1px solid var(--spectrum-global-color-gray-200, #e1e1e1);
  border-radius: 8px;
  padding: 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.admin-kpi-metric__title {
  font-size: 12px !important;
  font-weight: 600 !important;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--spectrum-global-color-gray-600) !important;
}

.admin-kpi-metric__value {
  font-size: 28px !important;
  font-weight: 700 !important;
  line-height: 1.2;
}

.admin-kpi-metric__subtitle {
  font-size: 12px !important;
  color: var(--spectrum-global-color-gray-500) !important;
}

/* Tooltip icon (ⓘ) shown next to labels that have a tooltip */
.admin-tooltip-icon {
  display: inline-block;
  margin-left: 4px;
  font-size: 12px;
  color: var(--spectrum-global-color-gray-500, #6e6e6e);
  cursor: help;
  vertical-align: middle;
}

/* Usage Bars */
.admin-usage-bar {
  height: 10px;
  background: var(--spectrum-global-color-gray-200, #e1e1e1);
  border-radius: 5px;
  overflow: hidden;
}

.admin-usage-bar__fill {
  height: 100%;
  border-radius: 5px;
  transition: width 0.5s ease;
  min-width: 2px;
}

/* Mini Bars (for tables) */
.admin-mini-bar {
  display: inline-block;
  width: 80px;
  height: 6px;
  background: var(--spectrum-global-color-gray-200, #e1e1e1);
  border-radius: 3px;
  overflow: hidden;
  vertical-align: middle;
}

.admin-mini-bar__fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.3s ease;
}

/* Detail Grid */
.admin-detail-grid {
  display: flex;
  flex-direction: column;
}

/* Error cell */
.admin-error-cell {
  max-width: 300px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--spectrum-global-color-red-600, #e34850);
  font-size: 13px;
}

/* Bar Chart */
.admin-bar-chart {
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 120px;
  padding: 8px 0;
  overflow-x: auto;
}

.admin-bar-chart__col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 20px;
  max-width: 40px;
  height: 100%;
}

.admin-bar-chart__bar-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
}

.admin-bar-chart__bar {
  width: 100%;
  border-radius: 2px 2px 0 0;
  min-height: 2px;
  transition: height 0.3s ease;
}

.admin-bar-chart__label {
  font-size: 9px;
  color: var(--spectrum-global-color-gray-500);
  margin-top: 4px;
  text-align: center;
  white-space: nowrap;
}

/* ========================================
   API CLIENT — Postman-style layout
   ======================================== */

.qc-workspace {
  display: flex;
  gap: 0;
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 8px;
  overflow: hidden;
  background: white;
  min-height: 600px;
}

/* --- Sidebar (Collection Panel) --- */

.qc-sidebar {
  width: 260px;
  flex-shrink: 0;
  border-right: 1px solid var(--spectrum-global-color-gray-200);
  background: var(--spectrum-global-color-gray-50);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.qc-sidebar__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 16px 12px;
  border-bottom: 1px solid var(--spectrum-global-color-gray-200);
}

.qc-sidebar__title {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  color: var(--spectrum-global-color-gray-600);
}

.qc-sidebar__count {
  font-size: 11px;
  font-weight: 600;
  background: var(--spectrum-global-color-gray-200);
  color: var(--spectrum-global-color-gray-700);
  padding: 1px 8px;
  border-radius: 10px;
}

.qc-sidebar__list {
  flex: 1;
  overflow-y: auto;
  padding: 8px 0;
}

.qc-sidebar__group {
  margin-bottom: 2px;
}

.qc-sidebar__group-header {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 8px 16px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--spectrum-global-color-gray-600);
  transition: background 0.15s;
}

.qc-sidebar__group-header:hover {
  background: var(--spectrum-global-color-gray-100);
}

.qc-sidebar__group-icon {
  font-size: 13px;
}

.qc-sidebar__group-name {
  flex: 1;
  text-align: left;
}

.qc-sidebar__group-count {
  font-size: 10px;
  font-weight: 600;
  background: var(--spectrum-global-color-gray-200);
  color: var(--spectrum-global-color-gray-600);
  padding: 0 6px;
  border-radius: 8px;
  line-height: 18px;
}

.qc-sidebar__chevron {
  font-size: 14px;
  transition: transform 0.2s;
  color: var(--spectrum-global-color-gray-400);
}

.qc-sidebar__chevron--open {
  transform: rotate(90deg);
}

.qc-sidebar__item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 7px 16px 7px 28px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 13px;
  color: var(--spectrum-global-color-gray-800);
  transition: all 0.15s;
  text-align: left;
}

.qc-sidebar__item:hover {
  background: var(--spectrum-global-color-gray-100);
}

.qc-sidebar__item--active {
  background: var(--spectrum-global-color-blue-50);
  color: var(--spectrum-global-color-blue-700);
  font-weight: 600;
  border-right: 3px solid var(--spectrum-global-color-blue-600);
}

.qc-sidebar__item-name {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* --- Method Badge --- */

.qc-method-badge {
  display: inline-block;
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.5px;
  color: white;
  text-transform: uppercase;
  line-height: 18px;
  flex-shrink: 0;
  min-width: 36px;
  text-align: center;
}

/* --- Detail Panel --- */

.qc-detail {
  flex: 1;
  min-width: 0;
  padding: 20px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* --- Endpoint Bar (editable) --- */

.qc-endpoint-bar {
  display: flex;
  align-items: center;
  gap: 0;
  border: 2px solid var(--spectrum-global-color-gray-300);
  border-radius: 6px;
  overflow: hidden;
  background: white;
  transition: border-color 0.15s;
}

.qc-endpoint-bar:focus-within {
  border-color: var(--spectrum-global-color-blue-500);
}

.qc-endpoint-bar__method {
  padding: 10px 14px;
  background: var(--spectrum-global-color-gray-100);
  font-size: 12px;
  font-weight: 800;
  color: var(--spectrum-global-color-gray-700);
  letter-spacing: 0.5px;
  border-right: 1px solid var(--spectrum-global-color-gray-300);
  flex-shrink: 0;
}

.qc-endpoint-bar__input {
  flex: 1;
  padding: 10px 14px;
  border: none;
  outline: none;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  font-size: 12px;
  color: var(--spectrum-global-color-gray-800);
  background: transparent;
  min-width: 0;
}

.qc-endpoint-bar__input::placeholder {
  color: var(--spectrum-global-color-gray-400);
}

/* --- Send Button --- */

.qc-send-btn {
  padding: 10px 20px;
  border: none;
  background: #1473E6;
  color: white;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
}

.qc-send-btn:hover {
  background: #0D66D0;
}

.qc-send-btn:disabled,
.qc-send-btn--sending {
  background: #90CAF9;
  cursor: not-allowed;
}

/* --- Request Panel (tabs: Query / Headers / Variables) --- */

.qc-request-panel {
  border: 1px solid var(--spectrum-global-color-gray-300);
  border-radius: 6px;
  overflow: hidden;
}

.qc-request-panel__tabs {
  display: flex;
  align-items: center;
  background: var(--spectrum-global-color-gray-100);
  border-bottom: 1px solid var(--spectrum-global-color-gray-300);
  padding: 0 8px;
}

.qc-request-panel__tab {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 16px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 12px;
  font-weight: 500;
  color: var(--spectrum-global-color-gray-600);
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
  margin-bottom: -1px;
}

.qc-request-panel__tab:hover {
  color: var(--spectrum-global-color-gray-800);
  background: var(--spectrum-global-color-gray-200);
}

.qc-request-panel__tab--active {
  color: var(--spectrum-global-color-blue-600);
  border-bottom-color: var(--spectrum-global-color-blue-600);
  font-weight: 600;
}

.qc-request-panel__badge {
  font-size: 10px;
  font-weight: 700;
  background: var(--spectrum-global-color-blue-600);
  color: white;
  padding: 0 6px;
  border-radius: 8px;
  line-height: 16px;
}

.qc-request-panel__spacer {
  flex: 1;
}

.qc-request-panel__hint {
  font-size: 11px;
  color: var(--spectrum-global-color-gray-400);
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
}

.qc-request-panel__body {
  background: white;
}

/* --- GraphQL Editor (textarea) --- */

.qc-editor {
  display: block;
  width: 100%;
  min-height: 280px;
  padding: 16px 20px;
  border: none;
  outline: none;
  resize: vertical;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', monospace;
  font-size: 12px;
  line-height: 1.6;
  color: #1e1e2e;
  background: white;
  tab-size: 2;
  box-sizing: border-box;
}

.qc-editor--short {
  min-height: 120px;
}

.qc-editor::placeholder {
  color: var(--spectrum-global-color-gray-400);
}

/* --- Headers Editor --- */

.qc-headers-editor {
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.qc-header-row {
  display: flex;
  gap: 8px;
  align-items: center;
}

.qc-header-row__key,
.qc-header-row__value {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 4px;
  font-size: 12px;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  color: var(--spectrum-global-color-gray-800);
  outline: none;
  transition: border-color 0.15s;
}

.qc-header-row__key:focus,
.qc-header-row__value:focus {
  border-color: var(--spectrum-global-color-blue-500);
}

.qc-header-row__key {
  max-width: 200px;
  font-weight: 600;
}

.qc-header-row__remove {
  width: 28px;
  height: 28px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 16px;
  color: var(--spectrum-global-color-gray-400);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s;
}

.qc-header-row__remove:hover {
  background: #FFEBEE;
  color: #C62828;
}

.qc-headers-editor__add {
  align-self: flex-start;
  padding: 6px 14px;
  border: 1px dashed var(--spectrum-global-color-gray-300);
  border-radius: 4px;
  background: none;
  cursor: pointer;
  font-size: 12px;
  font-weight: 500;
  color: var(--spectrum-global-color-blue-600);
  transition: all 0.15s;
  margin-top: 4px;
}

.qc-headers-editor__add:hover {
  background: var(--spectrum-global-color-blue-50);
  border-color: var(--spectrum-global-color-blue-400);
}

/* --- Meta Chips --- */

.qc-meta-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  background: var(--spectrum-global-color-gray-100);
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 20px;
  font-size: 11px;
  color: var(--spectrum-global-color-gray-700);
  font-weight: 500;
}

.qc-meta-chip--green {
  background: #E8F5E9;
  border-color: #C8E6C9;
  color: #2E7D32;
  font-weight: 600;
}

.qc-meta-chip--orange {
  background: #FFF3E0;
  border-color: #FFE0B2;
  color: #E65100;
  font-weight: 600;
}

.qc-meta-chip--blue {
  background: #E3F2FD;
  border-color: #BBDEFB;
  color: #1565C0;
  font-weight: 600;
}

.qc-meta-chip__label {
  color: var(--spectrum-global-color-gray-500);
  font-weight: 400;
}

.qc-meta-chip__value {
  font-weight: 600;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
  font-size: 11px;
}

/* --- Copy Button --- */

.qc-copy-btn {
  padding: 5px 12px;
  border: 1px solid var(--spectrum-global-color-gray-300);
  border-radius: 4px;
  background: white;
  font-size: 11px;
  font-weight: 600;
  color: var(--spectrum-global-color-gray-700);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
}

.qc-copy-btn:hover {
  background: var(--spectrum-global-color-gray-100);
  border-color: var(--spectrum-global-color-gray-400);
}

/* --- Response Panel --- */

.qc-response {
  border: 1px solid var(--spectrum-global-color-gray-300);
  border-radius: 6px;
  overflow: hidden;
}

.qc-response__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  background: var(--spectrum-global-color-gray-100);
  border-bottom: 1px solid var(--spectrum-global-color-gray-300);
  flex-wrap: wrap;
  gap: 8px;
}

.qc-response__header-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.qc-response__header-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.qc-response__status {
  font-size: 12px;
  font-weight: 700;
  padding: 2px 10px;
  border-radius: 4px;
}

.qc-response__status--ok {
  background: #E8F5E9;
  color: #2E7D32;
}

.qc-response__status--error {
  background: #FFEBEE;
  color: #C62828;
}

.qc-response__meta {
  font-size: 11px;
  color: var(--spectrum-global-color-gray-500);
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
}

.qc-response__tab {
  padding: 4px 10px;
  border: 1px solid var(--spectrum-global-color-gray-300);
  border-radius: 4px;
  background: white;
  font-size: 11px;
  font-weight: 500;
  color: var(--spectrum-global-color-gray-600);
  cursor: pointer;
  transition: all 0.15s;
}

.qc-response__tab:hover {
  background: var(--spectrum-global-color-gray-200);
}

.qc-response__tab--active {
  background: var(--spectrum-global-color-blue-600);
  color: white;
  border-color: var(--spectrum-global-color-blue-600);
}

.qc-response__body {
  margin: 0;
  padding: 16px 20px;
  background: #1e1e2e;
  color: #a6e3a1;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', monospace;
  font-size: 12px;
  line-height: 1.6;
  overflow-x: auto;
  max-height: 500px;
  overflow-y: auto;
  white-space: pre;
}

/* --- Response Placeholder --- */

.qc-response-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  text-align: center;
  color: var(--spectrum-global-color-gray-500);
  border: 1px dashed var(--spectrum-global-color-gray-200);
  border-radius: 6px;
}

.qc-response-placeholder__icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.qc-response-placeholder__icon--spin {
  animation: qc-spin 1.5s ease-in-out infinite;
}

@keyframes qc-spin {
  0%, 100% { transform: rotate(0deg); }
  50% { transform: rotate(180deg); }
}

.qc-response-placeholder p {
  margin: 0;
  font-size: 13px;
  line-height: 1.5;
}

/* --- Empty / Welcome State --- */

.qc-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 60px 40px;
  color: var(--spectrum-global-color-gray-600);
}

.qc-empty__icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.qc-empty h3 {
  margin: 0 0 8px;
  font-size: 18px;
  font-weight: 700;
  color: var(--spectrum-global-color-gray-800);
}

.qc-empty__text {
  max-width: 500px;
  font-size: 13px;
  line-height: 1.6;
  color: var(--spectrum-global-color-gray-600);
  margin: 0 0 32px;
}

/* --- Feature Grid --- */

.qc-feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  max-width: 520px;
}

.qc-feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  padding: 20px 16px;
  background: var(--spectrum-global-color-gray-50);
  border: 1px solid var(--spectrum-global-color-gray-200);
  border-radius: 8px;
  transition: all 0.2s;
}

.qc-feature-card:hover {
  border-color: var(--spectrum-global-color-blue-400);
  box-shadow: 0 2px 8px rgba(20, 115, 230, 0.1);
}

.qc-feature-card__icon {
  font-size: 24px;
}

.qc-feature-card__label {
  font-size: 13px;
  font-weight: 700;
  color: var(--spectrum-global-color-gray-800);
}

.qc-feature-card__desc {
  font-size: 11px;
  color: var(--spectrum-global-color-gray-500);
  line-height: 1.4;
  text-align: center;
}

/* --- Responsive --- */

@media (max-width: 900px) {
  .qc-workspace {
    flex-direction: column;
  }
  .qc-sidebar {
    width: 100%;
    max-height: 200px;
    border-right: none;
    border-bottom: 1px solid var(--spectrum-global-color-gray-200);
  }
  .qc-feature-grid {
    grid-template-columns: 1fr;
  }
}
